export default {
  async fetch(request, env, ctx) {
    // ── CORS headers (allow your site domain + localhost for testing)
    const corsHeaders = {
      "Access-Control-Allow-Origin": "*",
      "Access-Control-Allow-Methods": "POST, OPTIONS",
      "Access-Control-Allow-Headers": "Content-Type",
    };

    // Handle CORS preflight
    if (request.method === "OPTIONS") {
      return new Response(null, { headers: corsHeaders });
    }

    // Only allow POST
    if (request.method !== "POST") {
      return new Response("Method not allowed", { status: 405 });
    }

    let body;
    try {
      body = await request.json();
    } catch {
      return new Response(JSON.stringify({ error: "Invalid JSON" }), {
        status: 400,
        headers: { ...corsHeaders, "Content-Type": "application/json" },
      });
    }

    const userMessage = (body.message || "").trim().slice(0, 800); // cap at 800 chars
    const history = Array.isArray(body.history) ? body.history.slice(-8) : []; // last 8 turns

    if (!userMessage) {
      return new Response(JSON.stringify({ error: "Empty message" }), {
        status: 400,
        headers: { ...corsHeaders, "Content-Type": "application/json" },
      });
    }

    // Build messages array for the model
    const messages = [
      { role: "system", content: SYSTEM_PROMPT },
      ...history.map((h) => ({
        role: h.role === "user" ? "user" : "assistant",
        content: String(h.content).slice(0, 400),
      })),
      { role: "user", content: userMessage },
    ];

    try {
      // Call Cloudflare Workers AI (free tier)
      const response = await env.AI.run("@cf/meta/llama-3.1-8b-instruct", {
        messages,
        max_tokens: 300,
        temperature: 0.7,
      });

      const reply =
        response?.response?.trim() ||
        "Hey! I'm having a quick moment — please try again or message us on Facebook 💬";

      return new Response(JSON.stringify({ reply }), {
        headers: {
          ...corsHeaders,
          "Content-Type": "application/json",
          "Cache-Control": "no-store",
        },
      });
    } catch (err) {
      console.error("AI error:", err);
      return new Response(
        JSON.stringify({
          reply:
            "Sorry, I'm having a moment! You can reach us directly at obbhack6@gmail.com or on Facebook 🙏",
        }),
        {
          headers: { ...corsHeaders, "Content-Type": "application/json" },
        }
      );
    }
  },
};

